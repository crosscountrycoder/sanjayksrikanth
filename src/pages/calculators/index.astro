---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<Layout>
	<main>
		<Breadcrumb crumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Calculators' },
		]} />
		<h1>Calculators</h1>

		<section>
			<h2>Atmosphere</h2>
			<ul>
				<li><a href="/calculators/atmosphere">U.S. standard atmosphere calculator</a> — pressure, temperature, density, viscosity, speed of sound, boiling point</li>
			</ul>
		</section>
	</main>
</Layout>

<style>
	ul {
		list-style: disc;
		padding-left: 1.5rem;
	}
</style>
